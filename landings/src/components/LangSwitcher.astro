---
/**
 * Language switcher — links to THIS page in every other locale.
 *
 * Deliberately a plain list of links, not a <select>: each language is a real
 * URL a crawler can follow and a person can open in a new tab, and it needs no
 * JavaScript. The full native label shows from 480px up; below that the 2-letter
 * badge takes over (see Lang.short — never a bare globe icon).
 *
 * It links to the SAME route in the other locale, not to that locale's home.
 * Sending a reader on /privacy/ back to / just to change language is how you
 * lose them.
 */
import { langs, localeHref, routeFromPath, type LangCode } from '../i18n/languages';
import { getCopy } from '../i18n/copy';

interface Props {
  locale: LangCode;
}
const { locale } = Astro.props;
const copy = getCopy(locale);

// The locale-independent route of the page we're on: "/ru/privacy/" → "/privacy/".
const route = routeFromPath(Astro.url.pathname);
---

<nav class="lang" aria-label={copy.langLabel}>
  <ul>
    {
      langs.map((l) => (
        <li>
          <a
            href={localeHref(l.code, route)}
            hreflang={l.tag}
            lang={l.tag}
            class:list={['lang-link', { current: l.code === locale }]}
            aria-current={l.code === locale ? 'true' : undefined}
          >
            <span class="full">{l.label}</span>
            <span class="short" aria-hidden="true">
              {l.short}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .lang ul {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .lang-link {
    display: block;
    padding: 0.3rem 0.5rem;
    border-radius: var(--brand-radius, 8px);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    line-height: 1;
  }
  .lang-link:hover {
    color: var(--color-text);
    text-decoration: none;
    background: var(--color-soft);
  }
  /* The current language is state, not a destination — but it stays a link so
     the control has the same shape in every locale and screen readers get
     aria-current rather than a missing item. */
  .lang-link.current {
    color: var(--color-text);
    background: var(--color-soft);
  }

  /* Full label from 480px up; the 2-letter badge below it. */
  .short {
    display: inline;
  }
  .full {
    display: none;
  }
  @media (min-width: 480px) {
    .short {
      display: none;
    }
    .full {
      display: inline;
    }
  }
</style>
