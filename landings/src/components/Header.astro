---
/**
 * Structure only; words come from i18n/copy/<locale>.ts.
 *
 * Nav links are anchors into the home page, so in a non-default locale they
 * have to resolve against THAT locale's home (`/ru/#features`), not the bare
 * anchor — otherwise a Russian reader clicking «Возможности» lands on the
 * English page.
 */
import { localeHref, type LangCode } from "../i18n/languages";
import { getCopy } from "../i18n/copy";
import LangSwitcher from "./LangSwitcher.astro";

interface Props {
  locale: LangCode;
}
const { locale } = Astro.props;
const copy = getCopy(locale);

const home = localeHref(locale, "/");
/** '#features' → '/ru/#features'; '/login' → '/login' (app routes are global). */
const navHref = (href: string) =>
  href.startsWith("#") ? `${home}${href}` : href;
---

<header class="site-header">
  <div class="container bar">
    <!-- `Template` is renamed to your extension id (capitalized) by customize.sh.
         Set site.tld in the copy module for a coloured TLD span, e.g. '.app'. -->
    <a href={home} class="brand" aria-label={copy.a11y.brandHome}>
      {copy.site.brand}{copy.site.tld && <span class="tld">{copy.site.tld}</span>}
    </a>

    <nav class="primary" aria-label={copy.a11y.primaryNav}>
      <ul>
        {copy.nav.map((l) => (
          <li>
            <a href={navHref(l.href)}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <LangSwitcher locale={locale} />

    <!-- The signed-in app mounts under a path prefix (see site-hosting-pattern). -->
    <a href="/login" class="btn signin">
      <span class="cta-full">{copy.site.navCta}</span>
      <span class="cta-short">{copy.site.navCtaShort}</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 64px;
  }
  .brand {
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-text);
  }
  .brand:hover {
    text-decoration: none;
  }
  .tld {
    color: var(--color-accent);
  }
  .primary {
    margin-left: auto;
  }
  .primary ul {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .primary a {
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .primary a:hover {
    color: var(--color-text);
    text-decoration: none;
  }
  .signin {
    background: var(--color-text);
    color: #fff;
    padding: 0.5rem 1.1rem;
    font-size: 0.9rem;
  }
  .signin:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }

  /* The long CTA is the default; the short form takes over where the header
     runs out of room. Russian runs ~15-30% longer than English, so this is not
     hypothetical — see site.navCtaShort in the copy contract. */
  .cta-short {
    display: none;
  }
  @media (max-width: 430px) {
    .cta-full {
      display: none;
    }
    .cta-short {
      display: inline;
    }
  }

  /* When the nav links collapse, the language switcher must NOT go with them —
     it takes over the space instead. A visitor on a phone in the wrong language
     has no other way out. */
  @media (max-width: 820px) {
    .primary {
      display: none;
    }
    .site-header :global(.lang) {
      margin-left: auto;
    }
  }
</style>
