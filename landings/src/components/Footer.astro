---
/**
 * Structure only; words come from i18n/copy/<locale>.ts.
 *
 * Every link is built through localeHref, so a locale's footer keeps the reader
 * inside that locale. Anchors resolve against the locale's own home; page
 * routes ('/privacy') get the locale prefix; absolute URLs pass through.
 */
import { localeHref, type LangCode } from "../i18n/languages";
import { getCopy } from "../i18n/copy";

interface Props {
  locale: LangCode;
}
const { locale } = Astro.props;
const copy = getCopy(locale);

// TODO(copy): bump when you fork this template. Deliberately a constant rather
// than new Date(): the build would otherwise silently rewrite it, and a footer
// year is not worth a rebuild-per-January.
const year = 2026;

const home = localeHref(locale, "/");
const SNEAT_URL = "https://sneat.co";

/**
 * '#features'  → '/ru/#features'   (anchor on the locale's own home)
 * '/privacy'   → '/ru/privacy'     (a landing page, per locale)
 * '/login'     → '/login'          (app route, shared across locales)
 * 'https://…'  → unchanged
 */
const APP_ROUTES = ["/login"];
const linkHref = (href: string) => {
  if (href.startsWith("#")) return `${home}${href}`;
  if (href.startsWith("http")) return href;
  if (APP_ROUTES.includes(href)) return href;
  return localeHref(locale, href);
};
---

<footer class="site-footer">
  <div class="container cols">
    <div class="brand-col">
      <a href={home} class="brand" aria-label={copy.a11y.brandHome}>
        {copy.site.brand}{copy.site.tld && <span class="tld">{copy.site.tld}</span>}
      </a>
      <p>{copy.footer.tagline}</p>
    </div>

    <nav class="col" aria-label={copy.a11y.productNav}>
      <h3>{copy.footer.productTitle}</h3>
      <ul>
        {copy.footer.product.map((l) => (
          <li>
            <a href={linkHref(l.href)}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="col" aria-label={copy.a11y.moreNav}>
      <h3>{copy.footer.moreTitle}</h3>
      <ul>
        <li>
          <a href={SNEAT_URL} target="_blank" rel="noopener">
            {copy.footer.legal.link}
          </a>
        </li>
        {copy.footer.more.map((l) => (
          <li>
            <a href={linkHref(l.href)}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="container legal">
    <p>
      &copy; {year} {copy.site.brand} · {copy.footer.legal.before}<a
        href={SNEAT_URL}
        target="_blank"
        rel="noopener">{copy.footer.legal.link}</a
      >{copy.footer.legal.after}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-soft);
    padding-block: var(--space-4) var(--space-2);
    margin-top: var(--space-5);
  }
  .cols {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
  }
  .brand {
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--color-text);
  }
  .brand:hover {
    text-decoration: none;
  }
  .tld {
    color: var(--color-accent);
  }
  .col h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }
  .col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .col a {
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .col a:hover {
    color: var(--color-text);
  }
  .legal {
    margin-top: var(--space-3);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }
  .legal p {
    font-size: 0.85rem;
    margin: 0;
  }

  @media (min-width: 720px) {
    .cols {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
